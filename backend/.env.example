PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
ENABLE_REAL_SEND=false

# Used to encrypt OAuth tokens and integration secrets in local demo storage.
ENCRYPTION_SECRET=replace_with_a_long_random_secret

# Optional AI provider. The app has a local scoring/drafting fallback if unset.
ANTHROPIC_API_KEY=

# Gmail OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/gmail/callback

# WhatsApp via Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=+14155238886

# WhatsApp via Meta Cloud API
META_WA_TOKEN=
META_PHONE_NUMBER_ID=

# Optional external job APIs
RAPIDAPI_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
