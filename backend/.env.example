PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
# Optional single-domain production URL. Railway deployments derive this automatically.
APP_BASE_URL=
# Optional when the API is hosted on a different public domain.
BACKEND_URL=
# For LAN access from other devices: FRONTEND_URL=http://192.168.x.x:3000
ENABLE_REAL_SEND=true
ENABLE_DRY_RUN_SEND=false
SESSION_TTL_HOURS=168
# Avoid rewriting session persistence on every authenticated API request.
SESSION_TOUCH_INTERVAL_MINUTES=5
PASSWORD_RESET_BASE_URL=http://localhost:3000
# Local/dev can return a reset link in the API response. Keep false in production unless you have a protected internal flow.
ENABLE_PASSWORD_RESET_TOKEN_RESPONSE=false
# Production defaults to requiring email verification for password accounts. Set false only for a controlled private deployment.
REQUIRE_EMAIL_VERIFICATION=true
EMAIL_VERIFICATION_BASE_URL=http://localhost:3000
# Local/dev can return a verification link in the API response. Keep false in production unless you have a protected internal flow.
ENABLE_EMAIL_VERIFICATION_TOKEN_RESPONSE=false
SUPPORT_EMAIL=ai.jobpilot@gmail.com
# Optional IndexNow key for Bing/Yandex-style instant indexing notifications.
INDEXNOW_KEY=

# Production persistence. When DATABASE_URL is set, JobPilot uses PostgreSQL.
# Run `npm run migrate:postgres --workspace=backend` once to copy the existing SQLite data.
DATABASE_URL=
PG_POOL_MAX=10
PGSSL=false
PGSSL_REJECT_UNAUTHORIZED=true
# Normalized PostgreSQL rollout controls. Enable in this order: PREPARE, DUAL_WRITE, ENABLED.
POSTGRES_ROW_STORE_PREPARE=false
POSTGRES_ROW_STORE_DUAL_WRITE=false
POSTGRES_ROW_STORE_ENABLED=false

# Optional transactional email for production password resets.
APP_NAME=JobPilot AI
APP_VERSION=2.0.1
# Business Gmail SMTP. Use a Google app password for SMTP_PASS; never commit the real value.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-business@gmail.com
SMTP_PASS=
SMTP_FROM="JobPilot AI <your-business@gmail.com>"
SMTP_REPLY_TO=your-business@gmail.com
# New client accounts receive one welcome email when SMTP is configured.

# Separate owner-side agent that sends product/application updates to opted-in clients.
CLIENT_UPDATE_AGENT_ENABLED=true
CLIENT_UPDATE_AGENT_NAME=JobPilot Client Update Agent
CLIENT_UPDATE_PERSONALIZATION_ENABLED=true
# Uses safe activity summaries only; raw CVs and message bodies are never sent for personalization.
CLIENT_UPDATE_GEMINI_PERSONALIZATION=true
# Automatic release-note emails for meaningful client UI and feature changes.
CLIENT_UPDATE_SOFTWARE_AUTO_ENABLED=true
CLIENT_UPDATE_SOFTWARE_SCAN_INTERVAL_MS=60000
CLIENT_UPDATE_SOFTWARE_QUIET_MS=300000
# Batch multiple settled changes into at most one digest during this window.
CLIENT_UPDATE_SOFTWARE_MIN_DIGEST_INTERVAL_MS=1800000
CLIENT_UPDATE_LAUNCH_PROGRESS_PERCENT=80
CLIENT_UPDATE_LAUNCH_STATUS=Core client features, Gmail delivery, Google sign-in, CV webpages, and owner update tools are being finalized for launch.

# Owner APIs are disabled by default in production. Enable only on the separately deployed owner backend.
ENABLE_OWNER_PORTAL=false
# When enabled, the owner UI is served at /owner/ and can use Google login restricted to OWNER_EMAIL.

# Required when the owner portal is enabled. Password is optional when Google OAuth is configured.
OWNER_EMAIL=owner@yourdomain.com
OWNER_PASSWORD=
# Protect password logins with a one-time visual bot check and an emailed six-digit code.
LOGIN_CAPTCHA_ENABLED=false
LOGIN_2FA_ENABLED=false

# Optional in dev — omit to use built-in demo secret. If set, must be 64 hex chars.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=

# Gemini is required for generative Pro features. Local scoring remains available without it.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# Stripe subscription billing. Keep live keys only in Railway variables.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_EMPLOYER_PLUS_MONTHLY_PRICE_ID=
STRIPE_TRIAL_DAYS=0

# Google OAuth2 for official account sign-in and Gmail sending.
# Add both redirect URLs in the Google Cloud OAuth client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional on a single-domain Railway deployment; both are derived automatically.
GOOGLE_AUTH_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:4000/api/gmail/callback

# WhatsApp via Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=+14155238886

# WhatsApp via Meta Cloud API
META_WA_TOKEN=
META_PHONE_NUMBER_ID=
META_GRAPH_API_VERSION=

# Optional external job APIs
# JSEARCH_API_KEY and RAPIDAPI_KEY are aliases; set either one.
JSEARCH_API_KEY=
RAPIDAPI_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=
