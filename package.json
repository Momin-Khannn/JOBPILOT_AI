{
  "name": "jobpilot-ai",
  "version": "2.0.1",
  "private": true,
  "type": "module",
  "description": "Review-first AI job application assistant for web and mobile PWA demos.",
  "workspaces": [
    "frontend",
    "admin-portal",
    "employer-portal",
    "backend",
    "desktop"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\" \"npm run dev --workspace=admin-portal\" \"npm run dev --workspace=employer-portal\"",
    "build": "npm run build --workspace=frontend && npm run build --workspace=admin-portal && npm run build --workspace=employer-portal",
    "start": "npm run start --workspace=backend",
    "desktop": "npm run build --workspace=frontend && npm run start --workspace=desktop",
    "desktop:install": "npm run dist --workspace=desktop",
    "fix:sqlite": "npm rebuild better-sqlite3 --workspace=backend",
    "test": "npm run test --workspace=backend",
    "check": "npm run test && npm run build --workspace=frontend && npm run build --workspace=admin-portal && npm run build --workspace=employer-portal",
    "verify:deployment": "node scripts/verify-deployment.mjs",
    "submit:indexnow": "node scripts/submit-indexnow.mjs",
    "grant:lifetime-pro": "node scripts/grant-lifetime-pro.mjs",
    "publish:cv-profile": "node scripts/publish-cv-profile.mjs",
    "publish:all-cv-profiles": "node scripts/publish-all-cv-profiles.mjs",
    "db:rows:migrate": "node scripts/migrate-postgres-row-store.mjs",
    "db:rows:verify": "node scripts/verify-postgres-row-store.mjs",
    "db:rows:restore": "node scripts/restore-postgres-snapshot.mjs",
    "db:rows:verify-auth": "node scripts/verify-row-store-auth.mjs",
    "client-updates:diagnose": "node scripts/diagnose-client-update.mjs",
    "client-updates:send-current": "node scripts/send-current-client-release.mjs",
    "client-updates:verify-mailbox": "node scripts/verify-business-mailbox.mjs",
    "gmail:reset-connections": "node scripts/reset-gmail-connections.mjs",
    "client-updates:mark-failed": "node scripts/mark-failed-client-release.mjs"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1"
  }
}
